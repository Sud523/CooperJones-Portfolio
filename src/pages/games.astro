---
import Layout from "../components/Layout.astro";
import ProjectExplorer from "../components/ProjectExplorer.astro";
import { projectsForTrack } from "../data/projects";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<Layout
  title="Game development"
  description="Unity, VR, level design, and gameplay systems by Cooper Jones — videos, screenshots, and technical breakdowns."
>
  <div class="container page-title">
    <p class="kicker">Games</p>
    <h1>Game Development</h1>
    <p class="muted" style="max-width:70ch;">
      Gameplay programming, technical design, and level craft with a focus on clear systems,
      stable mechanics, and responsive interaction design. Work emphasizes iteration,
      playtesting, and building mechanics that communicate intent through play.
    </p>
  </div>

  <section class="page-section" style="padding-top:0">
    <div class="container" id="projects">
      <ProjectExplorer
        projects={projectsForTrack("games")}
        tagTrack="games"
        layout="list"
      />
    </div>
  </section>
</Layout>
