---
import Layout from "../components/Layout.astro";
import { asset } from "../lib/paths";
import { skillGroups } from "../data/skills";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const description =
  "Cooper Jones — software engineer and game developer building gameplay systems, Unity experiences, and polished web software.";
---

<Layout title="Home" {description} variant="home">
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-grid">
      <div>
        <p class="kicker">Portfolio</p>
        <h1>Software engineer &<br /> game developer</h1>
        <p class="hero-lead">
          I build reliable software and player-focused interactive systems across Unity, VR, and
          web platforms. Experienced developing features end-to-end, from gameplay and 
          interaction design to implementation, debugging, and delivery.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary" href={`${base}software.html#projects`}>View projects</a>
          <a class="btn btn-ghost" href={`${base}resume.html`}>Resume</a>
          <a class="btn btn-ghost" href={`${base}contact.html`}>Contact</a>
        </div>
        <div>
          <p class="kicker" style="margin-top:1.25rem;">Featured skills</p>
          <div class="pill-list" aria-label="Highlighted skills">
            <span class="pill">C#</span>
            <span class="pill">TypeScript</span>
            <span class="pill">Unity</span>
            <span class="pill">Gameplay Systems</span>
            <span class="pill">VR / XR</span>
            <span class="pill">Web Performance</span>
            <span class="pill">AI-Assisted Development</span>
          </div>
        </div>
      </div>
      <div class="hero-media">
        <div class="hero-shot">
          <img src={asset("Images/Hero1.png")} alt="Gameplay still from Don't Stop Climbing" loading="eager" fetchpriority="high" width="1200" height="675" />
        </div>
        <div class="hero-shot">
          <img src={asset("Images/Hero2.png")} alt="Second gameplay still from Don't Stop Climbing" loading="eager" width="1200" height="675" />
        </div>
      </div>
    </div>
    <a class="scroll-hint" href="#tracks" aria-label="Scroll to overview">⌄</a>
  </section>

  <section class="page-section" id="tracks">
    <div class="container">
      <header class="section-head">
        <p class="kicker">How I work</p>
        <h2>Two disciplines, one standard</h2>
        <p>
          Whether building software or game experiences, I focus on clarity, performance,
          and maintainability for both the people using the product and the people working on it.
        </p>
      </header>
      <div class="card-grid cols-3">
        <article class="card track-card">
          <h3>Software engineering</h3>
          <p>
            Building reliable applications, tools, and systems with a focus on readability,
            maintainability, and practical problem solving. Comfortable working across frontend,
            backend, and feature implementation.
          </p>
          <a class="card-link" href={`${base}software.html`}>Explore software work →</a>
        </article>
        <article class="card track-card">
          <h3>Game development</h3>
          <p>
            Developing gameplay systems, level flow, and interactive mechanics in Unity with an
            emphasis on player experience, iteration, and clean technical foundations.
          </p>
          <a class="card-link" href={`${base}games.html`}>Explore game work →</a>
        </article>
        <article class="card track-card">
          <h3>Technical design</h3>
          <p>
            Bridging creative direction and implementation by turning design goals into structured,
            testable systems that support both player experience and development workflows.
          </p>
          <a class="card-link" href={`${base}about.html`}>Read background →</a>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <header class="section-head section-head--compact">
        <p class="kicker">Stack</p>
        <h2>Skills Snapshot</h2>
      </header>
      <div class="skill-grid">
        {
          skillGroups.map((g) => (
            <div class="skill-block">
              <h3>{g.title}</h3>
              <ul>
                {g.items.map((i) => (
                  <li>{i}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var el = document.querySelector("a.scroll-hint");
      if (!el) return;
      function upd() {
        el.classList.toggle("scroll-hint--away", (window.scrollY || 0) > 40);
      }
      window.addEventListener("scroll", upd, { passive: true });
      upd();
    })();
  </script>
</Layout>
