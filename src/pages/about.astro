---
import Layout from "../components/Layout.astro";
import { experience } from "../data/experience";
---

<Layout
  title="About"
  description="Background, technical interests, and career direction for Cooper Jones — software engineer and game developer."
>
  <div class="container page-title page-title--about-gap">
    <p class="kicker">About</p>
    <h1>Biography & Focus</h1>
    <p class="muted" style="max-width:70ch;">
      I am a recent graduate from the College of Charleston with a B.A. in Game Development
      and a minor in Computer Science. I work across software engineering and game development 
      with a focus on building systems that feel clear, responsive, and intentional. Whether 
      developing gameplay, tools, or web applications, I care about maintainability, iteration speed,
      and creating experiences that feel intuitive to use.
    </p>
  </div>

  <section class="page-section" style="padding-top:0">
    <div class="container">
      <div class="about-sections">
        <section class="about-section" aria-labelledby="about-summary-heading">
          <h2 id="about-summary-heading">Professional Summary</h2>
          <p>
            I am a software engineer and game developer with deep experience in Unity,
            gameplay programming, and technical design. I enjoy owning features from whiteboard to
            release: clarifying requirements, implementing readable C# or TypeScript, and validating
            with playtests or user feedback.
          </p>
          <p>
            My background spans gameplay systems, technical design, frontend/backend development, and
            interactive tools, with an emphasis on practical problem solving and user-focused design.
          </p>
        </section>

        <section class="about-section" aria-labelledby="about-tech-heading">
          <h2 id="about-tech-heading">Technical Interests</h2>
          <ul>
            <li>Gameplay systems with responsive controls and readable player feedback</li>
            <li>Developer tools and workflows that improve iteration speed and usability</li>
            <li>Accessible, performant web experiences with clean frontend architecture</li>
            <li>Designing interactive experiences that feel intuitive, engaging, and rewarding to explore</li>
          </ul>
        </section>

        <section class="about-section" aria-labelledby="about-goals-heading">
          <h2 id="about-goals-heading">Career Goals</h2>
          <p>
            I am seeking opportunities where I can continue growing as both an engineer and
            interactive developer while contributing to collaborative teams building games,
            tools, or user-focused software products.
          </p>
        </section>

        <section
          class="about-section about-section--no-top-rule"
          aria-labelledby="exp-overview-heading"
        >
          <p class="kicker">My Journey so Far</p>
          <h2 id="exp-overview-heading">Experience Overview</h2>
          <div class="about-exp-entries">
            {
              experience.map((e) => (
                <div class="about-exp-block">
                  <h3>{e.title}</h3>
                  <p class="about-exp-meta muted">
                    <strong style="color:var(--text)">{e.org}</strong>
                    <span class="period"> · {e.period}</span>
                  </p>
                  <p>{e.summary}</p>
                  <ul>
                    {e.highlights.map((h) => (
                      <li>{h}</li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </section>
</Layout>
