---
import Layout from "../components/Layout.astro";
import ProjectExplorer from "../components/ProjectExplorer.astro";
import { projectsForTrack } from "../data/projects";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<Layout
  title="Software engineering"
  description="Software engineering projects by Cooper Jones — web, tools, and systems work with clear outcomes and links to demos or source."
>
  <div class="container page-title">
    <p class="kicker">Software</p>
    <h1>Software Engineering</h1>
    <p class="muted" style="max-width:70ch;">
      Projects in web development, tools, and systems engineering with a focus on clear structure,
      practical outcomes, and accessible interfaces. Includes stack tags and links to source or demos
      for quick review.
    </p>
  </div>

  <section class="page-section" style="padding-top:0">
    <div class="container" id="projects">
      <ProjectExplorer
        projects={projectsForTrack("software")}
        tagTrack="software"
        layout="list"
      />
    </div>
  </section>
</Layout>
