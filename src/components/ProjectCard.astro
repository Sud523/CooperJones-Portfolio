---
import { asset } from "../lib/paths";
import { resolveHref } from "../lib/links";
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const tagStr = project.tags.map((t) => t.toLowerCase()).join(" ");
---

<article class="project-card" data-project-card data-tags={tagStr}>
  <div>
    <p class="kicker" style="margin:0 0 0.35rem;">{project.kind}</p>
    <h3>{project.title}</h3>
    <p class="project-meta">{project.role}</p>
    <p>{project.tagline}</p>
    {project.about.trim() ? <p>{project.about}</p> : null}
    <p>
      <strong style="color:var(--text)">Design focus</strong> — {project.designGoal}
    </p>
    <p><strong style="color:var(--text)">Key contributions</strong></p>
    <ul>
      {project.keyContributions.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
    <div class="tag-row" aria-label="Technologies">
      {project.stack.map((s) => (
        <span class="tag">{s}</span>
      ))}
    </div>
  </div>

  {
    project.video && (
      <div>
        <p class="kicker" style="margin:0 0 0.35rem;">Video</p>
        <div class="video-shell">
          <iframe
            src={project.video.src}
            title={project.video.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          />
        </div>
      </div>
    )
  }

  {
    project.gallery.length > 0 && (
      <div>
        <p class="kicker" style="margin:0 0 0.35rem;">Gallery</p>
        <div class="gallery">
          {project.gallery.map((g) => (
            <button
              type="button"
              data-full-src={asset(g.src)}
              data-alt={g.alt}
              aria-label={`Open image: ${g.alt}`}
            >
              <img src={asset(g.src)} alt={g.alt} loading="lazy" decoding="async" />
            </button>
          ))}
        </div>
      </div>
    )
  }

  <div class="project-actions">
    {
      project.links.map((l) => (
        <a
          class:list={["btn", l.label.toLowerCase().includes("play") && "btn-primary"]}
          href={resolveHref(l.href, l.external)}
          target={l.external ? "_blank" : undefined}
          rel={l.external ? "noreferrer" : undefined}
        >
          {l.label}
        </a>
      ))
    }
  </div>
</article>
