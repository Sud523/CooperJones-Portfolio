---
import { person } from "../site.config";
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="muted" style="margin:0 0 0.5rem;">
        <strong style="color:var(--text)">{person.name}</strong> — {person.headline}
      </p>
      <p class="muted" style="margin:0;">
        © {year} {person.name}. Built with Astro for fast static hosting on GitHub Pages.
      </p>
    </div>
    <div class="footer-links">
      <a href={person.github} target="_blank" rel="noreferrer">GitHub</a>
      <a href={person.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <a href={person.itch} target="_blank" rel="noreferrer">itch.io</a>
      <a href={`${base}contact.html`}>Contact</a>
    </div>
  </div>
</footer>
