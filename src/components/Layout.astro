---
import "../styles/global.css";
import NavBar from "./NavBar.astro";
import Footer from "./Footer.astro";
import { person } from "../site.config";

interface Props {
  title: string;
  description: string;
  variant?: "home" | "default";
}

const { title, description, variant = "default" } = Astro.props;
const pageTitle = `${title} | ${person.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const assetBase = new URL(import.meta.env.BASE_URL, Astro.site);
const ogImage = new URL("Images/Hero1.png", assetBase).href;

const personUrl = new URL(import.meta.env.BASE_URL, Astro.site).href;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: person.name,
  jobTitle: person.headline,
  email: person.email.replace(/^mailto:/i, ""),
  url: personUrl,
  sameAs: person.sameAs.filter((u) => u && !u.includes("your-profile")),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0c0c0f" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="sr-only" href="#main-content">Skip to content</a>
    <NavBar variant={variant} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <div
      class="lightbox-backdrop"
      id="lightbox-root"
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      aria-label="Image preview"
    >
      <div class="lightbox-dialog">
        <button type="button" class="lightbox-close" data-lightbox-close>Close</button>
        <button type="button" class="lightbox-nav lightbox-prev" data-lightbox-prev aria-label="Previous image">
          ‹
        </button>
        <img src="" alt="" data-lightbox-img />
        <button type="button" class="lightbox-nav lightbox-next" data-lightbox-next aria-label="Next image">
          ›
        </button>
      </div>
    </div>

    <script is:inline>
      (function () {
        var backdrop = document.getElementById("lightbox-root");
        if (!backdrop) return;
        var imgEl = backdrop.querySelector("[data-lightbox-img]");
        var closeBtn = backdrop.querySelector("[data-lightbox-close]");
        var prevBtn = backdrop.querySelector("[data-lightbox-prev]");
        var nextBtn = backdrop.querySelector("[data-lightbox-next]");
        var galleryButtons = function () {
          return Array.prototype.slice.call(
            document.querySelectorAll(".gallery button[data-full-src]"),
          );
        };
        var list = [];
        var index = -1;
        var lastFocus = null;

        function syncList() {
          list = galleryButtons();
        }

        function openAt(i) {
          syncList();
          if (!list.length || i < 0 || i >= list.length) return;
          index = i;
          var src = list[index].getAttribute("data-full-src");
          var alt = list[index].getAttribute("data-alt") || "";
          imgEl.setAttribute("src", src);
          imgEl.setAttribute("alt", alt);
          backdrop.classList.add("is-open");
          backdrop.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden";
          lastFocus = document.activeElement;
          closeBtn.focus();
        }

        function close() {
          backdrop.classList.remove("is-open");
          backdrop.setAttribute("aria-hidden", "true");
          document.body.style.overflow = "";
          imgEl.setAttribute("src", "");
          index = -1;
          if (lastFocus && typeof lastFocus.focus === "function") lastFocus.focus();
        }

        function step(delta) {
          syncList();
          if (!list.length || index < 0) return;
          index = (index + delta + list.length) % list.length;
          var src = list[index].getAttribute("data-full-src");
          var alt = list[index].getAttribute("data-alt") || "";
          imgEl.setAttribute("src", src);
          imgEl.setAttribute("alt", alt);
        }

        document.addEventListener(
          "click",
          function (e) {
            var t = e.target;
            if (!t || !t.closest) return;
            var btn = t.closest("button[data-full-src]");
            if (!btn) return;
            syncList();
            var i = list.indexOf(btn);
            if (i !== -1) openAt(i);
          },
          true,
        );

        backdrop.addEventListener("click", function (e) {
          if (e.target === backdrop) close();
        });
        if (closeBtn) closeBtn.addEventListener("click", close);
        if (prevBtn) prevBtn.addEventListener("click", function () { step(-1); });
        if (nextBtn) nextBtn.addEventListener("click", function () { step(1); });

        document.addEventListener("keydown", function (e) {
          if (!backdrop.classList.contains("is-open")) return;
          if (e.key === "Escape") close();
          else if (e.key === "ArrowRight") step(1);
          else if (e.key === "ArrowLeft") step(-1);
        });
      })();
    </script>
  </body>
</html>
